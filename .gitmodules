[submodule "root/.config/nvim"]
	path = root/.config/nvim
	url = https://github.com/joshslawrence/nvim
[submodule "root/.config/tmux/plugins/catppuccin/tmux"]
	path = root/.config/tmux/plugins/catppuccin/tmux
	url = https://github.com/catppuccin/tmux.git
[submodule "root/.config/tmux/plugins/tpm"]
	path = root/.config/tmux/plugins/tpm
	url = https://github.com/tmux-plugins/tpm.git
